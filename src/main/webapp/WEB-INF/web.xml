<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xml.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xml.jcp.org/xml/ns/javaee
         http://xml.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>简易购物网站</display-name>
    <description>Java Web期末作业 - 购物网站</description>

    <!-- 欢迎页面 -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- 编码过滤器 -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.shop.filter.EncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 会话过期时间（30分钟） -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- 错误页面 -->
    <error-page>
        <error-code>404</error-code>
        <location>/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error/500.jsp</location>
    </error-page>
</web-app>
